# Copy this file to mcp-deploy.env and fill in real values.
#   cp mcp-deploy.env.example mcp-deploy.env
# mcp-deploy.env is git-ignored and loaded automatically by mcp-deploy.sh.

# Deploy target (DigitalOcean VPS)
VPS_USER="your-vps-user"
VPS_HOST="your.vps.ip.address"
VPS_PASS="your-vps-ssh-password"

# Optional — only needed for the PyPI publish step
PYPI_TOKEN="pypi-..."
